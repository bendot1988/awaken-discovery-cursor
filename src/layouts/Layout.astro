---
import "../styles/global.css";

interface Props {
	title?: string;
	description?: string;
}

const {
	title = "Awaken Discovery | Counselling and Psychotherapy",
	description = "Counselling and psychotherapy in Market Weighton, East Yorkshire.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			rel="stylesheet"
			href="https://fonts.googleapis.com/css2?family=Bonheur+Royale&family=Cormorant+Garamond:wght@500&family=Poppins:ital,wght@0,300;0,400;0,500;0,700;1,300&display=swap"
		/>
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{title}</title>
	</head>
	<body>
		<slot />
	</body>
</html>
