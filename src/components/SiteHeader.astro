---
import type { NavItem } from "../data/site";

interface Props {
	navItems: NavItem[];
}

const { navItems } = Astro.props;
---

<header class="site-header">
	<div class="container header-inner">
		<a href="#" class="brand" aria-label="Awaken Discovery home">
			<img src="/assets/logos/awaken-discovery-logo.png" alt="Awaken Discovery logo" />
		</a>

		<nav class="desktop-nav" aria-label="Primary">
			<ul class="nav-list">
				{
					navItems.map((item) => (
						<li><a href={item.href}>{item.label}</a></li>
					))
				}
			</ul>
		</nav>

		<a class="cta cta-solid header-cta" href="#contact">Book Your Taster Session</a>

		<details class="mobile-menu">
			<summary aria-label="Toggle menu">Menu</summary>
			<nav aria-label="Mobile">
				<ul>
					{
						navItems.map((item) => (
							<li><a href={item.href}>{item.label}</a></li>
						))
					}
				</ul>
			</nav>
		</details>
	</div>
</header>

<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 20;
		background: rgb(255 255 255 / 95%);
		border-bottom: 1px solid var(--color-gainsboro);
		backdrop-filter: blur(8px);
	}

	.header-inner {
		display: grid;
		grid-template-columns: auto 1fr auto;
		gap: 1rem;
		align-items: center;
		padding-block: 0.7rem;
	}

	.brand img {
		width: min(220px, 40vw);
	}

	.desktop-nav {
		justify-self: center;
	}

	.nav-list {
		display: flex;
		gap: 1rem;
		align-items: center;
		margin: 0;
		padding: 0;
		list-style: none;
		font-size: 0.84rem;
		font-weight: 400;
		text-transform: capitalize;
	}

	.nav-list a {
		color: var(--color-dark-gray);
		transition: color 0.2s ease;
	}

	.nav-list a:hover,
	.nav-list a:focus-visible {
		color: var(--color-dark-slate-gray);
	}

	.mobile-menu {
		display: none;
		justify-self: end;
	}

	.mobile-menu summary {
		list-style: none;
		cursor: pointer;
		font-size: 0.85rem;
		font-weight: 500;
		text-transform: uppercase;
	}

	.mobile-menu nav {
		position: absolute;
		right: 1rem;
		top: calc(100% - 0.2rem);
		width: min(280px, 90vw);
		padding: 1rem;
		background: var(--color-white);
		border: 1px solid var(--color-gainsboro);
		border-radius: 0.7rem;
		box-shadow: 0 10px 26px rgb(0 0 0 / 12%);
	}

	.mobile-menu ul {
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.mobile-menu li + li {
		margin-top: 0.7rem;
	}

	@media (max-width: 1024px) {
		.desktop-nav,
		.header-cta {
			display: none;
		}

		.mobile-menu {
			display: block;
		}

		.header-inner {
			grid-template-columns: auto 1fr;
		}
	}
</style>
